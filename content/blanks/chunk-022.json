  {
    "id": "bank-b-q015",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "optical-media",
    "stem": "A CD-RW has a speed rating of 12x 10x 32x. What do the three numbers refer to in order?",
    "options": [
      {
        "label": "A",
        "text": "Write, rewrite, read",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Read, write, rewrite",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Rewrite, read, write",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Write, read, rewrite",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "CD-RW drives are rated in write x rewrite x read order, so 12x 10x 32x means 12x write, 10x rewrite, 32x read. The shortcut for the exam: the read speed is always the largest of the three numbers because reading is the fastest operation, so the 32x has to sit in the last position, which rules out every other ordering.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 16
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "71e9e8aac7aebdd189a67a83fdbd405ba6ceab98"
  },
  {
    "id": "bank-b-q016",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "memory-types",
    "stem": "The information stored in _______ is erased when the computer is turned off",
    "options": [
      {
        "label": "A",
        "text": "ROM",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "RAM",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "BIOS",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "CPU",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "RAM is volatile: its cells need power to hold their charge, so contents are lost when the machine is switched off. ROM and the BIOS chip are non-volatile and keep their contents without power, and the CPU is a processor, not storage.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 17
    },
    "keyProvenance": "inline_bold",
