  {
    "id": "bank-a-q021",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "optical-media",
    "stem": "Typical acronym of reusable optical storage will be......",
    "options": [
      {
        "label": "A",
        "text": "CD",
        "isCorrect": false
      },
      {
        "label": "B",
