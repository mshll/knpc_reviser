  {
    "id": "bank-a-q006",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "backup-media",
    "stem": "Which device is used to back up the data?",
    "options": [
      {
        "label": "A",
        "text": "Floppy Disk",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Tape",
