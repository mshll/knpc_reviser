  {
    "id": "bank-a-q191",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "logic-gates",
    "stem": "The output of logic circuit given below represents ______ gate.",
    "stemFigure": "/figures/bank-a-q191.png",
    "options": [
