  {
    "id": "bank-a-q185",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "logic-gates",
    "stem": "The output of an AND gate with three inputs, A, B, and C, is HIGH when ________.",
    "options": [
      {
        "label": "A",
        "text": "A = 1, B = 1, C = 0",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "A = 0, B = 0, C = 0",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "A = 1, B = 1, C = 1",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "A = 1, B = 0, C = 1",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "An AND gate outputs 1 only when every input is 1, so A = B = C = 1 is the single HIGH row of the truth table. Any input at 0 forces the output to 0.",
