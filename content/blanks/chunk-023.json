  },
  {
    "id": "bank-b-q047",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "pc-hardware",
    "stem": "ESD would cause the most damage to which component?",
    "options": [
      {
        "label": "A",
        "text": "Power supply",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Expansion board",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Monitor",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Keyboard",
        "isCorrect": false
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "ESD destroys low-voltage semiconductor logic, which sits exposed on expansion boards; a static discharge too small for you to feel is already enough to damage a chip. Power supplies, monitors and keyboards handle far higher voltages and currents and are comparatively rugged.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 12
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "d91e750c48c0a39540f2e22cbbaac9be27797d17"
  },
  {
    "id": "bank-b-q048",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "dos-commands",
    "stem": "To view any currently running Terminate Stay Resident (TSR's) programs you could type:",
    "options": [
      {
        "label": "A",
        "text": "Memory",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "MEM",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "SYS /M",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Memmaker",
        "isCorrect": false
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "The DOS MEM command (usually MEM /C) lists the programs currently loaded in conventional and upper memory, which is exactly how you see resident TSRs. MEMMAKER is the trap: it optimizes memory usage rather than reporting it, and 'Memory' is not a DOS command at all.",
