    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "5e168cbc8fc44340559736437bb0b389a548447c"
  },
  {
    "id": "bank-b-q035",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "cabling",
    "stem": "What type of connector is used to plug a telephone line into a modem?",
    "options": [
      {
        "label": "A",
        "text": "COM1",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "RJ-45",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "RJ-11",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "RJ-10",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "RJ-11 is the small 6-position jack used for analogue telephone lines, which is what plugs into a dial-up modem. RJ-45 is the classic trap: it is the 8-position Ethernet connector, physically wider and used for LAN cabling.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 36
    },
    "keyProvenance": "inline_bold",
