  {
    "id": "bank-b-q033",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "acronyms",
    "stem": "WYSIWYG is an acronym for what?",
    "options": [
      {
        "label": "A",
        "text": "What You Saw Is What You Got",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "What You See Is What You Get",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "What You Seen Is What You Gotten",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "What You Sow Is What You Get",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "WYSIWYG stands for What You See Is What You Get: the editing view on screen matches the printed or published output. The other options are made-up tense variations of the same phrase.",
    "source": {
