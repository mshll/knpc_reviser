  {
    "id": "ce2016-q016",
    "type": "mcq",
    "topic": "software-engineering",
    "subtopic": "software-maintenance",
    "stem": "Which of the following is NOT a kind of software maintenance?",
    "options": [
      {
        "label": "A",
