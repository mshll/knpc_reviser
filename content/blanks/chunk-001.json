  {
    "id": "ce2016-q003",
    "type": "mcq",
    "topic": "data-structures-algorithms",
    "subtopic": "asymptotic-complexity",
    "stem": "Which one has a better Algorithm Complexity?",
    "options": [
      {
        "label": "A",
        "text": "O(n)",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "O(n²)",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "O(lg n)",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "O(n lg n)",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Best complexity means slowest growth: lg n < n < n lg n < n^2 for large n. At n = 1,000,000, lg n is about 20 operations while n^2 is 10^12, so O(lg n) wins.",
    "source": {
      "file": "[CE] questions.pdf",
      "exam": "K-Companies",
      "year": 2016,
      "tier": "gold",
      "originalNumber": 3
    },
