  },
  {
    "id": "mock2018-q055",
    "type": "mcq",
    "topic": "data-structures-algorithms",
    "subtopic": "hashing",
    "stem": "What is the load factor?",
    "options": [
      {
        "label": "A",
        "text": "Average array size.",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Average key size.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Average chain length.",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "None of the mentioned.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "In simple chaining, load factor is the average number of elements stored in a chain, and is given by the ratio of number of elements stored to the number of slots in the array.",
    "explanationSource": "source",
    "source": {
      "file": "Test 3.zip",
      "exam": "mock",
      "year": 2018,
      "tier": "practice",
      "originalNumber": 55
