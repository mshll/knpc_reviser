  {
    "id": "mock2018-q053",
    "type": "mcq",
    "topic": "data-structures-algorithms",
    "subtopic": "hashing",
    "stem": "What is a hash function?",
    "options": [
      {
        "label": "A",
        "text": "A function has allocated memory to keys.",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "A function that computes the location of the key in the array.",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "A function that creates an array.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of the mentioned.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "In a hash table, there are fewer array positions than the keys, so the position of the key in the array has to be computed, this is done using the hash function.",
    "explanationSource": "source",
