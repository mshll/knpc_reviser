  {
    "id": "bank-a-q155",
    "type": "mcq",
    "topic": "databases",
    "subtopic": "dbms-basics",
    "stem": "What is DBMS?",
    "options": [
      {
        "label": "A",
        "text": "DBMS is a collection of queries",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "DBMS is a high-level language",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "DBMS is a programming language",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "DBMS stores, modifies and retrieves data",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "A DBMS is the software layer that stores, modifies and retrieves data on behalf of users and applications. It is not a language: SQL is the language, and the DBMS is the system that executes it.",
