  {
    "id": "bank-a-q148",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "eeprom",
    "stem": "What does EEPROM stands for?",
    "options": [
      {
        "label": "A",
        "text": "Electrically Erasable and Programmable Read-Only Memory",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Electronically Erasable and Programmable Read-Only Memory",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Electrically Enabled and Programmable Read-Only Memory",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "EEPROM = Electrically Erasable Programmable Read-Only Memory, so erased electrically rather than by UV light (that would be EPROM). The trap is 'Electronically', which sounds right but is not the standard expansion.",
