  {
    "id": "bank-a-q149",
    "type": "mcq",
    "topic": "computer-architecture",
    "subtopic": "isa",
    "stem": "CISC stands for -",
    "options": [
      {
        "label": "A",
        "text": "Complex Instruction Set Computer",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Complete Instruction Sequential Compilation",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Complex Instruction Sequential Compiler",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "CISC = Complex Instruction Set Computer, the design style with many multi-step instructions and variable-length encodings (x86). Its counterpart is RISC (Reduced Instruction Set Computer), with few fixed-length, single-cycle instructions.",
