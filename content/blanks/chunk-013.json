  {
    "id": "koc2012-q023",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "ms-excel",
    "stem": "For what Wrap Text check box is used?",
    "options": [
      {
        "label": "A",
        "text": "Wrap text inside a file",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Wrap text inside the margin",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Wrap text inside the cell",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Wrap Text (Format Cells > Alignment) breaks long text onto multiple lines inside the cell boundary and grows the row height to fit. It is a cell-level alignment setting and has nothing to do with page margins or the file.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "bank",
      "year": 2012,
      "originalNumber": 23
    },
