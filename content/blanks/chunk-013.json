  {
    "id": "koc2012-q028",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "ms-office",
    "stem": "What is Print Preview",
    "options": [
      {
        "label": "A",
        "text": "Shows how a file looks, when it is printed",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Prints the current document",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Shows, the table how it will print",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "Print Preview renders the whole file as it will appear on the printed page (pagination, margins, headers and footers) without sending anything to the printer. Option B describes the Print command itself, and option C wrongly narrows the preview to tables only.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "bank",
      "year": 2012,
      "originalNumber": 28
    },
