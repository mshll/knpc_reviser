  {
    "id": "koc2012-q020",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "ms-excel",
    "stem": "What is Page Break Preview?",
    "options": [
      {
        "label": "A",
        "text": "An editing view that displays your work sheet how it will print",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "An editing view to draw objects in a work sheet",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "An editing view to draw charts in excel",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "Page Break Preview is an editing view that shows the worksheet divided into printed pages, with the page breaks drawn as lines you can drag to change what lands on each page. It is still fully editable, it just previews the print layout; drawing objects and charts are unrelated features.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "bank",
      "year": 2012,
      "originalNumber": 20
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [
      "legacy"
    ],
    "dedupeHash": "6f4a3422d9f3030eca0aeaf81e88c95e5abf3c2c"
  },
  {
    "id": "koc2012-q021",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "ms-excel",
    "stem": "Auto Filter command is under which Menu?",
    "options": [
      {
        "label": "A",
        "text": "Data Menu",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Tools Menu",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Insert Menu",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "AutoFilter operates on a data list, so it sits on the Data menu (Data > Filter > AutoFilter in menu-era Excel; Data tab > Filter in the ribbon). Tools held options and macros, Insert held objects and functions.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "bank",
      "year": 2012,
      "originalNumber": 21
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [
      "legacy"
    ],
    "dedupeHash": "fca06f2f5a02c3c8fd6e46fcb1232b40136adac4"
  },
  {
    "id": "koc2012-q022",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "ms-excel",
    "stem": "What Ctrl + P key board shortcut is for?",
    "options": [
      {
        "label": "A",
        "text": "To paste an object you copied",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "To close the excel application",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "To print the spread sheet",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Ctrl+P is the standard Print shortcut across Office and almost every Windows application. The distractors are other shortcuts: Ctrl+V pastes and Alt+F4 closes the application.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "bank",
      "year": 2012,
      "originalNumber": 22
    },
