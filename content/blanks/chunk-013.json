  {
    "id": "koc2012-q029",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "ms-office",
    "stem": "What is the function of Office Assistant?",
    "options": [
      {
        "label": "A",
        "text": "To automate the commands",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "To save the file automatically.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Providing the help topics & tips.",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "The Office Assistant (Clippy) surfaced context-sensitive help topics and usage tips. It did not automate commands (that is what macros do) or save files automatically (that is AutoSave/AutoRecover).",
    "source": {
