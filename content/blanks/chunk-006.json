    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "5b0a86197b8a735918ff45497b6a3f28c66a533e"
  },
  {
    "id": "koc2012-q077",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "memory-types",
    "stem": "The computer term SRAM stands for:",
    "options": [
      {
        "label": "A",
        "text": "Synchronous memory",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Static memory",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Serial memory",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "SRAM stands for Static RAM, that is static memory. It is called static because it holds its contents for as long as power is applied, with no refresh cycle, unlike DRAM (Dynamic RAM) which must be refreshed continuously.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 77
    },
