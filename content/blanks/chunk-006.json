  {
    "id": "koc2012-q068",
    "type": "mcq",
    "topic": "programming",
    "subtopic": "language-fundamentals",
    "stem": "What are the major components of a programming language?",
    "options": [
      {
        "label": "A",
        "text": "Commands and Procedures",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Commands, Procedures, and Program Logic",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Syntax and Semantics",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Syntax and Language Rules",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "A programming language is defined by its syntax (the legal form of statements) and its semantics (what those statements mean when executed). Commands, procedures and program logic are things you write in a language, not the components that define one.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 68
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "e560b29cb3a0c1bb15721941b9cdcd46a04c4e36"
  },
  {
    "id": "koc2012-q069",
    "type": "mcq",
    "topic": "programming",
    "subtopic": "program-definition",
    "stem": "The term Computer Program can be defined as follows:",
    "options": [
      {
        "label": "A",
        "text": "Detailed set of instructions that tells the computer what to do.",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Detailed set of instructions to only read files and print reports.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Both 1 and 2.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of the above.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "A computer program is a detailed set of instructions that tells the computer what to do. Option B ('only read files and print reports') is an artificially narrow subset of that, so 'Both 1 and 2' fails: B is not a valid definition on its own.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 69
    },
