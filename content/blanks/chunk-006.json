  },
  {
    "id": "koc2012-q079",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "units",
    "stem": "MBPs stand for:",
    "options": [
      {
        "label": "A",
        "text": "Mega bits per second",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Mega Bytes per second",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "Mbps means megabits per second, with a lowercase b for bits. Mega Bytes per second is the classic trap: a byte is 8 bits, so MB/s is 8 times larger than Mb/s. Network link speeds are quoted in bits per second by convention.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 79
