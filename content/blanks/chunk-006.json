    "verificationLevel": "derived",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "56ce4159d4259f3fc4bb5937c5a61df36d1a3be0"
  },
  {
    "id": "koc2012-q067",
    "type": "mcq",
    "topic": "software-engineering",
    "subtopic": "sdlc",
    "stem": "The first two phases of Software Development Process are:",
    "options": [
      {
        "label": "A",
        "text": "Requirement Analysis and Specification",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Software Design and Specification.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Software Design and Coding.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Coding and Testing",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "The classic SDLC waterfall order is requirement analysis and specification, then design, then coding, then testing. You cannot design or code before the requirements are captured and written down, which rules out every option that leads with design or coding.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 67
    },
