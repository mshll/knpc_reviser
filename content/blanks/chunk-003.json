  },
  {
    "id": "ce2016-q068",
    "type": "mcq",
    "topic": "data-structures-algorithms",
    "subtopic": "asymptotic-complexity",
    "stem": "Big-O is used for ____________ .",
    "options": [
      {
        "label": "A",
        "text": "Best case.",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Worst case.",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Average case.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of the above.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "Big-O is an asymptotic upper bound, so by convention it is used to state the worst case. Omega is the lower bound (best case) and Theta is a tight bound; the trap is assuming Big-O means 'average', which it does not.",
    "source": {
      "file": "[CE] questions.pdf",
      "exam": "K-Companies",
