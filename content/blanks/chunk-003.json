    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "37ea993ae2b0adb58c7ba8a27fcbd755a3fd557d"
  },
  {
    "id": "knpc2016-q005",
    "type": "mcq",
    "topic": "data-structures-algorithms",
    "subtopic": "graph-algorithms",
    "stem": "Shortest path is solved by which algorithm?",
    "options": [
      {
        "label": "A",
        "text": "Bellman–Ford algorithm",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Prim",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Dijkstra",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "DFS (Depth First Search)",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Dijkstra is the canonical single-source shortest-path algorithm, greedily settling the nearest unvisited node (valid only for non-negative edge weights). The item is technically flawed: Bellman-Ford also solves shortest path and additionally handles negative weights, so A is not really wrong - the exam wants Dijkstra.",
