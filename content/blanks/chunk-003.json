  {
    "id": "ce2016-q066",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "state-machines",
    "stem": "The outputs in Moore State Machine depends on:",
    "options": [
      {
        "label": "A",
        "text": "Current state & current input.",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Current state & previous state.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Current state only.",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Current input only.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "In a Moore machine the output is a function of the current state alone, so the output is labelled inside the state bubble. Option A describes a Mealy machine, where the output depends on both the current state and the current input.",
    "source": {
      "file": "[CE] questions.pdf",
      "exam": "K-Companies",
      "year": 2016,
      "tier": "gold",
      "originalNumber": 66
    },
