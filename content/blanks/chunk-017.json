    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "7f2ae1024add0979a845b3fa2eb95ffd6ef37095"
  },
  {
    "id": "bank-a-q093",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "hardware-basics",
    "stem": "A computer’s hard disk is",
    "options": [
      {
        "label": "A",
        "text": "an arithmetic and logical unit",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "computer software",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "an operating system",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "computer hardware",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "A hard disk is a physical component you can touch, so it is hardware. It stores the operating system and software, but it is not itself either of those, which is the trap in options B and C.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
