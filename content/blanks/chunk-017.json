  },
  {
    "id": "bank-a-q091",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "io-devices",
    "stem": "Which of the following is an example of an input device?",
    "options": [
      {
        "label": "A",
        "text": "scanner",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "speaker",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "CD",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "printer",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "A scanner converts a paper image into digital data and feeds it into the computer, so it is an input device. Speaker and printer are outputs, and a CD is storage media, not a device.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 14
