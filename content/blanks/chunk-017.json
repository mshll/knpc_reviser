  {
    "id": "bank-a-q105",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "computer-history",
    "stem": "First generation computer systems used",
    "options": [
      {
        "label": "A",
        "text": "Transistors",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Vacuum Tubes",
