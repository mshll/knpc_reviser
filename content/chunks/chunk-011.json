  {
    "id": "ce2016-q028",
    "type": "short_answer",
    "topic": "digital-logic",
    "subtopic": "flip-flops",
    "stem": "What is the truth table for T-flipflop?",
    "options": [],
    "answerOptionLabels": [],
    "answerText": "[T-FF] Truth Table:\nT = 0 → Q(t+1) = Q(t)\nT = 1 → Q(t+1) = Q(t)'\nEquation → Qt+1 = T Qt' + T' Qt",
    "answerFigure": "/figures/ce2016-q028-answer.png",
    "source": {
      "file": "[CE] solutions.pdf",
      "exam": "K-Companies",
