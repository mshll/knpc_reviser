  },
  {
    "id": "ce2016-q029",
    "type": "short_answer",
    "topic": "digital-logic",
    "subtopic": "flip-flops",
    "stem": "What is the truth table for JK-flipflop?",
    "options": [],
    "answerOptionLabels": [],
    "answerText": "[JK-FF] Truth Table:\nJ = 0, K = 0 → Q(t+1) = Q(t)\nJ = 0, K = 1 → Q(t+1) = 0\nJ = 1, K = 0 → Q(t+1) = 1\nJ = 1, K = 1 → Q(t+1) = Q(t)'\nEquation → Qt+1 = J Qt' + K' Qt",
    "answerFigure": "/figures/ce2016-q029-answer.png",
    "source": {
      "file": "[CE] solutions.pdf",
      "exam": "K-Companies",
      "year": 2016,
      "tier": "gold",
      "originalNumber": 29
