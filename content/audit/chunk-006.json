    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "ab716e74e7d730176497adcd0435f56a7ef4976c"
  },
  {
    "id": "koc2012-q041",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "logic-gates",
    "stem": "In two input OR Gate, if both inputs are 1, what will be the output?",
    "options": [
      {
        "label": "A",
        "text": "Zero",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "One",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Two",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Unknown",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "OR outputs 1 whenever at least one input is 1, so 1 OR 1 = 1. Do not confuse OR with XOR: XOR would give 0 here because it outputs 1 only when the inputs differ.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 41
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "604ff7dc43a8368b5c9cd0797dcb88e183772d6d"
  },
  {
    "id": "koc2012-q042",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "logic-gates",
    "stem": "If two input NOR Gate, if both inputs are 1, what will be the output?",
    "options": [
      {
        "label": "A",
        "text": "Zero",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "One",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Two",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Unknown",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "NOR is OR followed by NOT: 1 OR 1 = 1, then inverted gives 0. A NOR gate outputs 1 only when both inputs are 0.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 42
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
