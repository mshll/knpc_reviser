    "dedupeHash": "27d87d576dc95d041b0b67ede57d199822ceb3d7"
  },
  {
    "id": "koc2012-q043",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "flip-flops",
    "stem": "What do R and S stand for in RS-flip flop?",
    "options": [
      {
        "label": "A",
        "text": "R- Reset; S- Set",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "R- Reset; S- Snooze",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "R- Rest; S- Set",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "R- Rest; S- Snooze",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "In an RS (SR) flip-flop, S is Set (drives Q to 1) and R is Reset (drives Q to 0). The other options are nonsense words placed to catch careless reading.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 43
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
