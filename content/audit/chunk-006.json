  {
    "id": "koc2012-q010",
    "type": "mcq",
    "topic": "number-systems",
    "subtopic": "units",
    "stem": "How many bits are in a byte?",
    "options": [
      {
        "label": "A",
        "text": "32",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "16",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "8",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "4",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "A byte is 8 bits by definition. 4 bits is a nibble, and 16 or 32 bits describe word sizes, not bytes.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
