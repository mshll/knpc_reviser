  },
  {
    "id": "koc2012-q044",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "flip-flops",
    "stem": "What will be the output from RS-flip flop under the condition of R=1 and S=0 ?",
    "options": [
      {
        "label": "A",
        "text": "The output is reset to zero",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "The output is set to one",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "The output is set to zero",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "The output is reset to one",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "R=1 with S=0 asserts the Reset input, so Q goes to 0. Option C is the trap: 'set to zero' misuses the word set, which in flip-flop terminology specifically means driving the output to 1. Note R=1 and S=1 together is the forbidden/invalid state.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 44
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "cb96bb9295f9aaaf3709ac4b652b2e18b7b1d59f"
  },
