    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "eb33ac24e9bc6a2f797d887ebd7f8193a95886bb"
  },
  {
    "id": "koc2012-q015",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "modem",
    "stem": "The main function of a modem from engineering point of view is:",
    "options": [
      {
        "label": "A",
        "text": "To connect from one destination to another",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "To convert binary codes to hexadecimal codes",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "To convert analog signals to digital signals and vice versa",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "To convert binary codes to ASCII codes",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Modem is short for modulator/demodulator: it modulates outgoing digital data onto an analog carrier for transmission over an analog line, and demodulates the incoming analog signal back into digital data. It performs no code conversion (binary to hex or ASCII), which rules out B and D.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 15
    },
