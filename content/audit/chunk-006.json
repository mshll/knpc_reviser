  {
    "id": "koc2012-q011",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "disk-geometry",
    "stem": "What is a Cylinder on a magnetic disk pack?",
    "options": [
      {
        "label": "A",
        "text": "One disk surface",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Group of tracks that are vertically aligned on a disk pack",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Group of tracks that are horizontally aligned on a disk pack",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "All of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "In a disk pack each platter surface has tracks at the same radii; the cylinder is the set of all same-numbered tracks stacked vertically across every surface. It matters because the whole cylinder can be read with the head assembly in one position, so no seek is needed between its tracks.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 11
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "4eaf34a3ec4cbc11b6c5aa32dfde22a384b1992a"
  },
  {
