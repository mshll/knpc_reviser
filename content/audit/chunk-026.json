  },
  {
    "id": "bank-a-q196",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "proxy-server",
    "stem": "A proxy server is used as the computer?",
    "options": [
      {
        "label": "A",
        "text": "with external access",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "acting as a backup",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "performing file handling",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "accessing user permissions",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "A proxy server is the intermediary machine that holds the external (Internet) connection and makes outbound requests on behalf of internal clients, so the internal hosts never talk to the outside directly. Backup, file handling and permissions are jobs of other servers.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 4
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "44ce9d337febe38c83369f052f9ef0cb97afb850"
  },
  {
    "id": "bank-a-q197",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "security",
    "stem": "Which software prevents the external access to a system?",
    "options": [
      {
        "label": "A",
        "text": "Firewall",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Gateway",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Router",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Virus checker",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "A firewall inspects traffic against a rule set and blocks unauthorised inbound connections, which is exactly 'preventing external access'. Routers and gateways forward traffic rather than filter it, and a virus checker targets malware already on the machine.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 5
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "f76dc0a203c400f1faa8b2eed10cbd2631abe097"
  },
  {
    "id": "bank-a-q198",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "security",
    "stem": "Which one of the following would breach the integrity of a system?",
    "options": [
      {
        "label": "A",
        "text": "Looking the room to prevent theft",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Full access rights for all users",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Fitting the system with an anti-theft device",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Protecting the device against willful or accidental damage",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "Integrity means data cannot be altered by unauthorised parties. Giving every user full access rights lets anyone modify or delete data, so integrity is breached. The other options are physical security measures, which protect availability and the hardware, not data correctness.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 6
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "8e443001f16029bdddcee216d762514acc1ddcb2"
  },
  {
    "id": "bank-a-q199",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "ipv4",
    "stem": "The maximum length (in bytes) of an IPv4 datagram is?",
    "options": [
      {
        "label": "A",
        "text": "32",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "1024",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "65535",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "512",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "The IPv4 header's Total Length field is 16 bits, so the largest value it can hold is 2^16 - 1 = 65535, and that count covers header plus payload in bytes. 512 and 1024 are typical MTU-ish numbers, not the protocol maximum.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 7
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "de41a35413f51b24ebe3b1facc58f81de0301561"
  },
  {
    "id": "bank-a-q201",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "ip-addressing",
    "stem": "What IP address class allocates 8 bits for the host identification part?",
    "options": [
      {
        "label": "A",
        "text": "Class A",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Class B",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Class C",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Class D",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Class C splits the 32-bit address as 24 network bits + 8 host bits, giving 2^8 - 2 = 254 usable hosts per network. Class B leaves 16 host bits and Class A leaves 24; Class D is multicast and has no host part at all.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 9
    },
