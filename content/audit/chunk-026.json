  {
    "id": "bank-a-q204",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "osi-model",
    "stem": "Which layer of the TCP / IP stack corresponds to the OSI model transport layer?",
    "options": [
      {
        "label": "A",
        "text": "Host to host",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Application",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Internet",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Network Access",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "The TCP/IP stack's host-to-host layer (where TCP and UDP live) provides end-to-end delivery between processes, which is precisely OSI layer 4, the transport layer. Internet maps to OSI network (layer 3) and Network Access maps to OSI data link plus physical.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 12
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
