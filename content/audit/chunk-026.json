[
  {
    "id": "bank-a-q192",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "logic-gates",
    "stem": "If A = 1, B = 1, what will be the values of Y and Z?",
    "stemFigure": "/figures/bank-a-q192.png",
    "options": [
      {
        "label": "A",
        "text": "Y = 0, Z = 0",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Y = 1, Z = 0",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Y = 0, Z = 1",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Y = 1, Z = 1",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Trace both outputs: Y = A'.(A+B) and Z = Y + (A+B). With A = 1, B = 1: A' = 0, so Y = 0.(1) = 0; A + B = 1, so Z = 0 + 1 = 1. Hence Y = 0, Z = 1.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 9
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "a49d7cc1d73d9f6fa3dd0bb56659bb7eb0dd788d"
  },
  {
    "id": "bank-a-q193",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "switching",
    "stem": "Which of the following methods provides dedicated communication channel between two stations?",
    "options": [
      {
        "label": "A",
        "text": "Circuit switching",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Switch network",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Packet switching",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of these",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "Circuit switching reserves an end-to-end path (the classic telephone call) that stays dedicated to the two stations for the whole session. Packet switching is the distractor: it shares every link statistically and gives no dedicated channel.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 1
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "b9a34402a74c7563920546d88b258de7da18db4f"
  },
  {
    "id": "bank-a-q194",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "topology",
    "stem": "The most flexibility how devices are wired together is provided by",
    "options": [
      {
        "label": "A",
        "text": "T-switched networks",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Star networks",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Ring networks",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Bus networks",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "In a bus topology any device can tap the shared trunk cable at any point, so there is no central hub to home-run to and no closed loop to maintain, giving the most freedom in how the wiring is laid out. The question is loosely worded, but star and ring both impose a fixed cabling structure.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 2
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "7e051fdca34d10803767ded50a8bd5282797d679"
  },
  {
    "id": "bank-a-q195",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "lan",
    "stem": "Which of the following items is not used in local area network (LAN)?",
    "options": [
      {
        "label": "A",
        "text": "Cable",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Printer",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Modem",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Computer",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "A modem modulates data onto a telephone/WAN line to reach outside the site, so it belongs to the WAN side, not the LAN itself. Cable, printer and computer are all ordinary LAN components.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 3
    },
