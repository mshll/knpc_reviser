  },
  {
    "id": "bank-b-q103",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "printers",
    "stem": "What is the name of the computer terminal which gives paper printout?",
    "options": [
      {
        "label": "A",
        "text": "Display screen",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Soft copy terminal",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Hard copy terminal",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Plotter",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Paper output is \"hard copy\", screen output is \"soft copy\", so a terminal that prints on paper is a hard copy terminal. A plotter is a device, not a terminal.",
    "source": {
