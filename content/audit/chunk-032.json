  },
  {
    "id": "bank-b-q098",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "magnetic-tape",
    "stem": "What is the number of read-write heads in the drive for a 9-trac magnetic tape?",
    "options": [
      {
        "label": "A",
        "text": "9",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "16",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "18",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "27",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "A 9-track tape drive reads all 9 tracks in parallel, one head per track, so 9 heads. Legacy hardware trivia: the count of heads always equals the track count in the stem.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 8
    },
    "keyProvenance": "answer_page",
