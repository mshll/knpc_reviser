  {
    "id": "bank-b-q109",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "memory-operations",
    "stem": "Which of the following will happen when data is entered into a memory location?",
    "options": [
      {
        "label": "A",
        "text": "It will add to the content of the location",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "It will change the address of the memory location",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "It will erase the previous content",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "It will not be fruitful if there is already some data at the location",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Writing to a memory location is destructive: the new value overwrites whatever was there. Reading, by contrast, is non-destructive. The address of a location never changes, and there is no automatic accumulation of the old value with the new.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 19
    },
    "keyProvenance": "answer_page",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "b89b447caf37aa298a30b03c1f1349910070fdce"
  },
  {
    "id": "bank-b-q110",
    "type": "mcq",
    "topic": "computer-architecture",
    "subtopic": "buffering",
    "stem": "A storage area used to store data to a compensate for the difference in speed at which the different units can handle data is",
    "options": [
      {
        "label": "A",
        "text": "Memory",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Buffer",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Accumulator",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Address",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "A buffer is temporary storage placed between two units that run at different speeds (for example CPU and printer) so the fast unit can dump its output and carry on instead of waiting for the slow one. An accumulator is a CPU register for arithmetic results, and an address just names a location.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 20
