  {
    "id": "bank-b-q106",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "printers",
    "stem": "A kind of serial dot-matrix printer that forms characters with magnetically-charged ink sprayed dots is called",
    "options": [
      {
        "label": "A",
        "text": "Laser printer",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Ink-jet printer",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Drum printer",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Chan printer",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "An ink-jet printer sprays tiny charged ink droplets and deflects them onto the paper to build up a dot matrix, exactly as described. A laser printer fuses toner via a photoconductive drum, and drum and chain printers are impact line printers with fixed character shapes.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 16
    },
    "keyProvenance": "answer_page",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "dda29ef62f98a8b55fe4fa4fd68b658aecd5faf2"
  },
  {
    "id": "bank-b-q107",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "printers",
    "stem": "Which printer is very commonly used for desktop publishing?",
    "options": [
      {
        "label": "A",
        "text": "Laser printer",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Inkjet printer",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Daisywheel printer",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Dot matrix printer",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "Desktop publishing needs high-resolution, near-typeset page output, which is what laser printers deliver. Inkjet and dot-matrix were lower resolution, and a daisywheel can only print fixed character shapes, so it cannot render graphics or fonts at all.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 17
    },
    "keyProvenance": "answer_page",
