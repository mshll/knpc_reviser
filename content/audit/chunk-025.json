[
  {
    "id": "bank-a-q170",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "scheduling",
    "stem": "The FCFS algorithm is particularly troublesome for ____________",
    "options": [
      {
        "label": "A",
        "text": "operating systems",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "multiprocessor systems",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "time sharing systems",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "multiprogramming systems",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "FCFS is non-preemptive and has no time quantum, so one long CPU-bound job holds the processor until it finishes. That destroys response time in a time-sharing system, where every interactive user must get the CPU back at regular short intervals.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
