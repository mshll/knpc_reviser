        "isCorrect": false
      },
      {
        "label": "B",
        "text": "A = 0, B = 0, C = 0",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "A = 1, B = 1, C = 1",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "A = 1, B = 0, C = 1",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
