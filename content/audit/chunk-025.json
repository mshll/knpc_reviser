  {
    "id": "bank-a-q184",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "scheduling",
    "stem": "FIFO scheduling is",
    "options": [
      {
        "label": "A",
        "text": "Fair-share scheduling",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Deadline scheduling",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Non-preemptive scheduling",
