  },
  {
    "id": "bank-b-q091",
    "type": "mcq",
    "topic": "computer-architecture",
    "subtopic": "cpu-components",
    "stem": "The ALU of a computer responds to the commands coming from",
    "options": [
      {
        "label": "A",
        "text": "Primary memory",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Control section",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "External memory",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Cache memory",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "The control unit decodes each instruction and issues the control signals that tell the ALU which operation to perform, so the ALU responds to the control section. Memory (primary, cache, or external) only supplies operands and instructions; it does not command the ALU.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 1
    },
    "keyProvenance": "answer_page",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "f0b60458d54b633770ba2caa8adfc9e0d46de026"
  },
  {
    "id": "bank-b-q092",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "memory-operations",
    "stem": "The act of retrieving existing data from memory is called",
    "options": [
      {
        "label": "A",
        "text": "Read-out",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Read from",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Read",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "All of above",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "'Read', 'read-out', and 'read-from' are all accepted names for the operation of retrieving data already stored in memory, so 'All of above' is correct. Note that reading is non-destructive in modern memory: the data stays in place, unlike a write, which overwrites it.",
