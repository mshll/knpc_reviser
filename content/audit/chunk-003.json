  },
  {
    "id": "ce2016-q046",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "ram",
    "stem": "Random Access Memory is?",
    "options": [
      {
        "label": "A",
        "text": "Volatile.",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Non-Volatile.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "EPROM.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "ROM.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "RAM is volatile: it holds data only while powered, and its contents are lost at power-off. ROM and EPROM are the non-volatile counterparts, which is why they, and option B, are wrong here.",
    "source": {
