  {
    "id": "koc2012-q068",
    "type": "mcq",
    "topic": "programming",
    "subtopic": "language-fundamentals",
    "stem": "What are the major components of a programming language?",
    "options": [
      {
        "label": "A",
        "text": "Commands and Procedures",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Commands, Procedures, and Program Logic",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Syntax and Semantics",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Syntax and Language Rules",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "A programming language is defined by its syntax (the legal form of statements) and its semantics (what those statements mean when executed). Commands, procedures and program logic are things you write in a language, not the components that define one.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 68
    },
