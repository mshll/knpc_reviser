  },
  {
    "id": "koc2012-q061",
    "type": "mcq",
    "topic": "databases",
    "subtopic": "keys",
    "stem": "What is a secondary key of a file?",
    "options": [
      {
        "label": "A",
        "text": "The second key on a file.",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "The second field on a file that is used to access another file.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Any field that is used as a key to another file other than the primary key.",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "None of the above.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "A secondary key is any field other than the primary key that is used as an access key to retrieve records. The trap is reading 'secondary' positionally: it has nothing to do with being the second key or second field in the record.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 61
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "e27cc32f5f8b4a4fd324b0e8d3b71b202f7d21c2"
  },
  {
    "id": "koc2012-q062",
    "type": "mcq",
    "topic": "number-systems",
    "subtopic": "binary-to-decimal",
    "stem": "The decimal conversion of binary 0110 is:",
    "options": [
      {
        "label": "A",
        "text": "2",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "4",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "6",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "8",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Expand by place value from the right: 0110 = 0*8 + 1*4 + 1*2 + 0*1 = 4 + 2 = 6. The trap is misaligning the weights, for example reading only one of the two set bits, which lands you on 2 or 4.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 62
    },
    "keyProvenance": "inline_bold",
