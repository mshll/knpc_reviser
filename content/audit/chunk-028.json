  {
    "id": "bank-b-q016",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "memory-types",
    "stem": "The information stored in _______ is erased when the computer is turned off",
    "options": [
      {
        "label": "A",
        "text": "ROM",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "RAM",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "BIOS",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "CPU",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "RAM is volatile: its cells need power to hold their charge, so contents are lost when the machine is switched off. ROM and the BIOS chip are non-volatile and keep their contents without power, and the CPU is a processor, not storage.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 17
    },
    "keyProvenance": "inline_bold",
