    "topic": "general-it",
    "subtopic": "io-devices",
    "stem": "All the following are computer input devices except for",
    "options": [
      {
        "label": "A",
        "text": "Keyboard",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Printer",
