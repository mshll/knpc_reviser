    "needsReview": false,
    "flags": [],
    "dedupeHash": "a3cbc9d3d4c3695a6d027366ec7cd722d6f46f81"
  },
  {
    "id": "koc2012-q092",
    "type": "true_false",
    "topic": "databases",
    "subtopic": "null-values",
    "stem": "In Oracle a NULL value means that the value is not known.",
