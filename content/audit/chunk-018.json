  {
    "id": "bank-a-q028",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "cache",
    "stem": "Which of the following medium is used between CPU & RAM TO speed up the processing power of a CPU?",
    "options": [
      {
        "label": "A",
        "text": "Virtual Memory",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "D RAM",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Flash Memory",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Cache Memory",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "Cache memory sits between the CPU and main memory, holding recently and frequently used data in faster SRAM so the CPU stalls less often on slow RAM accesses. Virtual memory is the trap: it works in the opposite direction, extending RAM onto the much slower disk, so it adds latency rather than removing it.",
    "source": {
      "file": "exam noooow.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 29
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "f83b4c81e7a614b32e0afa60476ffc56246c0eec"
  },
  {
    "id": "bank-a-q029",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "paging",
    "stem": "Breaking logical memory into blocks of the same size is called as:",
    "options": [
      {
        "label": "A",
        "text": "Frames",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Segments",
        "isCorrect": false
      },
      {
