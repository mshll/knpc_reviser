  {
    "id": "bank-a-q024",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "ram",
    "stem": "When we work on any document on PC, it is stored temporarily on-",
    "options": [
      {
        "label": "A",
        "text": "RAM",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "ROM",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "CPU",
        "isCorrect": false
      },
      {
