  {
    "id": "bank-a-q031",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "secondary-storage",
    "stem": "Where, data will remain intact even when the computer is turned of",
    "options": [
      {
        "label": "A",
