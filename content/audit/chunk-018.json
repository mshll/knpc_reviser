  {
    "id": "bank-a-q030",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "ram",
    "stem": "Which one is random access memory-",
    "options": [
      {
        "label": "A",
        "text": "RAM",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "ROM",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "P-ROM",
        "isCorrect": false
      },
      {
        "label": "D",
