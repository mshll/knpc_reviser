  },
  {
    "id": "knpc2016-q113",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "data-link-protocols",
    "stem": "What is the main difference between DDCMP and SDLC?",
    "options": [
      {
        "label": "A",
        "text": "DDCMP does not need special hardware to final the beginning of a message",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "DDCMP has a message header",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "SDLC has an IP address",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "SDLC does not use CRC",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "DDCMP is byte-count (character-oriented): a count field in the header states the data length, so the receiver can find message boundaries in software with no special framing hardware. SDLC is bit-oriented and relies on hardware detection of the flag pattern 01111110 plus bit de-stuffing to locate the start of a message. D is wrong because SDLC does use CRC.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KNPC",
      "tier": "gold",
      "year": 2016,
      "originalNumber": 13
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "7aba779534795de5b641b929bfb85e832b427511"
  },
  {
    "id": "koc2012-q001",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "os-role",
    "stem": "The function of an Operating System is to:",
    "options": [
      {
        "label": "A",
        "text": "Process input data",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Manage and allocate computer hardware and software resources",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Display Error messages for computer operators",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Print reports",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "The OS is the resource manager: it allocates the CPU, memory, I/O devices and files among competing programs and users, and provides the interface between hardware and application software. Processing data, printing reports and showing errors are things applications or utilities do on top of the OS, not the OS's defining function.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 1
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "10728132e161cb0285e01337095c30f3b9e138c1"
  },
  {
    "id": "koc2012-q002",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "unix-commands",
    "stem": "What is the Unix command to display a file on a terminal, one screen-full at a time:",
