[
  {
    "id": "knpc2016-q030",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "signal-processing",
    "stem": "The receive equalizer reduces delay distortions using a",
    "options": [
      {
        "label": "A",
        "text": "tapped delay lines",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "gearshift",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "descrambler",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "difference engine",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "A receive equalizer is a transversal filter built from a tapped delay line: it takes copies of the signal delayed by successive tap intervals, weights them and sums them so the echoes cancel the intersymbol interference caused by delay distortion. The distractors are unrelated modem parts: a gearshift is speed fallback, a descrambler undoes scrambling, and a difference engine is a mechanical calculator.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KNPC",
      "tier": "gold",
      "year": 2016,
      "originalNumber": 30
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "double",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "ce1e84e16f87bd1e88e0ae6aa2f22751a8076a90"
  },
  {
    "id": "knpc2016-q101",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "paging",
    "stem": "Page traffic describes",
    "options": [
      {
        "label": "A",
        "text": "The pages in memory",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "The papers required to be brought is a given page request",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "The movement of pages in and out of the memory",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "The number of pages of executing programs loaded in memory",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "Page traffic is the rate at which pages are moved in and out of main memory (page-ins and page-outs), which is why excessive page traffic is the symptom of thrashing. Option D describes the resident set (how many pages are currently loaded), a static count, not the movement.",
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KNPC",
      "tier": "gold",
      "year": 2016,
      "originalNumber": 1
    },
