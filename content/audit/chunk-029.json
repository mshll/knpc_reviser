  },
  {
    "id": "bank-b-q036",
    "type": "mcq",
    "topic": "computer-architecture",
    "subtopic": "boot-process",
    "stem": "From what location are the 1st computer instructions available on boot up?",
    "options": [
      {
        "label": "A",
        "text": "ROM BIOS",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "CPU",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "boot.ini",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "CONFIG.SYS",
        "isCorrect": false
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "At power-on RAM is empty, so the CPU fetches its very first instruction from the reset vector, which is mapped to firmware held in ROM BIOS. boot.ini and CONFIG.SYS are files on disk, and reading a disk already requires running code, so they cannot be first.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 1
    },
    "keyProvenance": "inline_bold",
