  },
  {
    "id": "bank-b-q045",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "printers",
    "stem": "In laser printer technology, what happens during the conditioning stage?",
    "options": [
      {
        "label": "A",
        "text": "The corona wire places a uniform positive charge on the paper",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "A uniform negative charge is placed on the photosensitive drum",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "A uniform negative charge is placed on the toner",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "All of the above",
        "isCorrect": false
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "Conditioning (charging) is the stage where the primary corona wire or charge roller applies a uniform negative charge across the whole photosensitive drum; the laser then selectively discharges the areas that will pick up toner. Charging the paper is the transfer stage, not conditioning.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 10
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "80fdefdb15e72dab45c6f09de1f2c6407683196f"
  },
  {
    "id": "bank-b-q046",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "maintenance",
    "stem": "What product is used to clean smudged keys on a keyboard?",
    "options": [
      {
        "label": "A",
        "text": "TMC solvent",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Silicone spray",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Denatured alcohol",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "All-purpose cleaner",
        "isCorrect": true
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "Smudges on keycaps are ordinary grime, so a mild all-purpose cleaner on a cloth is what the bank keys as correct. Solvents and silicone spray can attack the plastic and the printed legends, and denatured alcohol is intended for contacts rather than casework.",
    "source": {
