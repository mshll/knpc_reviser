    "flags": [
      "legacy"
    ],
    "dedupeHash": "40338a7fa77657482b3c23d37bea7cb5b5461d18"
  },
  {
    "id": "bank-b-q038",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "pc-hardware",
    "stem": "Missing slot covers on a computer can cause?",
    "options": [
      {
        "label": "A",
        "text": "over heat",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "power surges",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "EMI.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "incomplete path for ESD",
        "isCorrect": false
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "Slot covers seal the case so the fans pull air along the intended path across the boards; with covers missing the airflow short-circuits and the machine overheats (and dust gets in). EMI is a defensible real-world second answer because the covers are part of the shield, but overheating is the keyed one.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 3
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "verificationLevel": "single",
    "needsReview": false,
    "flags": [],
    "dedupeHash": "e995a7ced8db5ff136336a0e325a8add22658508"
  },
  {
    "id": "bank-b-q039",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "pc-hardware",
    "stem": "When installing PCI NICS you can check the IRQ availability by looking at",
    "options": [
      {
        "label": "A",
        "text": "dip switches",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "CONFIG.SYS",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "jumper settings",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "motherboard BIOS",
        "isCorrect": true
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "PCI cards are jumperless and configured by Plug and Play, so there are no dip switches or jumpers to read. IRQ assignment and availability are shown in the motherboard BIOS setup under PnP/PCI configuration. CONFIG.SYS is a DOS text file and tracks no interrupts.",
    "source": {
