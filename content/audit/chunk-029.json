  },
  {
    "id": "bank-b-q042",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "disk-storage",
    "stem": "A hard disk is divided into tracks which are further subdivided into:",
    "options": [
      {
        "label": "A",
        "text": "clusters",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "sectors",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "vectors",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "heads",
        "isCorrect": false
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "Each platter surface has concentric tracks, and every track is divided into sectors, the smallest physically addressable unit on the disk (classically 512 bytes). Clusters are the trap: they are groups of sectors defined by the file system, not a subdivision of the disk geometry.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 7
