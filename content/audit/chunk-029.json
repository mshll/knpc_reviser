  },
  {
    "id": "bank-b-q040",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "network-devices",
    "stem": "With respect to a network interface card, the term 10/100 refers to",
    "options": [
      {
        "label": "A",
        "text": "protocol speed",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "a fiber speed",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "megabits per seconds",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "minimum and maximum server speed",
        "isCorrect": false
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "explanation": "10/100 means the NIC negotiates either 10 Mbps or 100 Mbps Ethernet, so the numbers are megabits per second. It is a link speed on copper (10BASE-T / 100BASE-TX), not a fiber rate and not a property of the protocol.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 5
    },
    "keyProvenance": "inline_bold",
