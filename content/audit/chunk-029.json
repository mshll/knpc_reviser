  {
    "id": "bank-b-q050",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "troubleshooting",
    "stem": "Suppose that you have a the maintenance package identifies several possible field replaceable units (FRUs) that will resolve the problem. What should you do after turning the power off?",
    "options": [
      {
        "label": "A",
        "text": "Replace the indicated parts, one at a time in the recommended sequence, until the problem is resolved; return unused FRUs to stock",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Replace all of the indicated FRUs at once and return the machine to the customer if the problem is resolved",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Follow the same procedure as in ays replace the system board first if it is on the list of possible FRUs If multiple FRUs are indicated, then software is the most likely source of the problem",
        "isCorrect": false
