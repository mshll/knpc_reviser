  {
    "id": "bank-b-q044",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "interfaces",
    "stem": "Which standard govern parallel communications?",
    "options": [
      {
        "label": "A",
        "text": "RS232",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "RS-232a",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "CAT 5",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "IEEE 1284",
        "isCorrect": true
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "IEEE 1284 is the standard for the PC parallel (printer) port, covering SPP, EPP and ECP modes. RS-232 is the trap: it is the serial standard, and CAT 5 is a cable specification rather than a communications standard.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 9
    },
    "keyProvenance": "inline_bold",
