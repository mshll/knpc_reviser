  },
  {
    "id": "bank-b-q043",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "pc-hardware",
    "stem": "A wrist grounding strap contains which of the following:",
    "options": [
      {
        "label": "A",
        "text": "Surge protector",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Capacitor",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Voltmeter",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Resistor",
        "isCorrect": true
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "An ESD wrist strap has roughly a 1 megohm resistor in series with its ground lead. That bleeds static charge off you slowly instead of instantly, and limits current to a safe level if you touch a live conductor while grounded.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
