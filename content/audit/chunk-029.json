  },
  {
    "id": "bank-b-q047",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "pc-hardware",
    "stem": "ESD would cause the most damage to which component?",
    "options": [
      {
        "label": "A",
        "text": "Power supply",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Expansion board",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Monitor",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Keyboard",
        "isCorrect": false
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "ESD destroys low-voltage semiconductor logic, which sits exposed on expansion boards; a static discharge too small for you to feel is already enough to damage a chip. Power supplies, monitors and keyboards handle far higher voltages and currents and are comparatively rugged.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 12
    },
    "keyProvenance": "inline_bold",
