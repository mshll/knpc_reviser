    "dedupeHash": "cd61df8072d4e62f3b526d7e9d43dd612229eaba"
  },
  {
    "id": "bank-b-q037",
    "type": "mcq",
    "topic": "hardware-memory",
    "subtopic": "troubleshooting",
    "stem": "What could cause a fixed disk error.",
    "options": [
      {
        "label": "A",
        "text": "No-CD installed",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "bad ram",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "slow processor",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Incorrect CMOS settings",
        "isCorrect": true
      },
      {
        "label": "E",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "explanation": "'Fixed disk' means the hard disk. Legacy BIOS stores the drive type and geometry in CMOS, so if those settings are wrong or the CMOS battery has failed, POST cannot address the drive and reports a fixed disk error. Bad RAM or a slow processor produce entirely different symptoms.",
    "source": {
      "file": "Computer Engineering K-Companies Exam - Questions.pdf",
      "exam": "bank",
      "tier": "bank",
      "originalNumber": 2
    },
