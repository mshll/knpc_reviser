  {
    "id": "mock2018-q048",
    "type": "mcq",
    "topic": "software-engineering",
    "subtopic": "uml",
    "stem": "In UML diagrams, relationship between object and component parts is represented by",
    "options": [
      {
        "label": "A",
        "text": "Ordination.",
