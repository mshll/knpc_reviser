    "stem": "What is the mail protocol?",
    "options": [
      {
        "label": "A",
        "text": "SMTP",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "POP3",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "IMAP",
        "isCorrect": false
      },
      {
        "label": "D",
