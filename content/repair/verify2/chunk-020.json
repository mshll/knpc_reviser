    "id": "mock2018-q036",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "adders",
    "stem": "The number of full and half-adders required to add 16-bit numbers is:",
    "options": [
      {
        "label": "A",
        "text": "8 half-adders, 8 full-adders.",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "1 half-adder, 15 full-adders.",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "16 half-adders, 0 full-adders.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "4 half-adders, 12 full-adders.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "explanation": "The one half-adder can add the least significant bit of the two numbers. Full adders are required to add the remaining 15 bits as they all involve adding carries.",
