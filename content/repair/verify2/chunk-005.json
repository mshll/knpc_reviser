  {
    "id": "ce2016-q052",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "deadlock",
    "stem": "What is the situation called when two processes are waiting for each other?",
    "options": [
      {
        "label": "A",
        "text": "Rolling Back.",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Deadlock.",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Starvation.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Dining Philosophers.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "source": {
      "file": "[CE] questions.pdf",
      "exam": "K-Companies",
      "year": 2016,
      "tier": "gold",
      "originalNumber": 52
    },
    "keyProvenance": "answer_page",
    "flags": [],
    "keyVerified": true,
    "needsReview": false,
    "dedupeHash": "634136bfeee41c055aecacb0e9d536407e33a912",
    "explanation": "Two processes each holding a resource the other needs and each waiting on the other is a circular wait, which is the textbook definition of deadlock. Starvation is the trap: there a process is indefinitely postponed but the rest of the system keeps making progress, whereas in deadlock neither process can ever proceed."
  },
  {
    "id": "ce2016-q053",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "osi-layers",
    "stem": "Which OSI layer is responsible for reliable communication?",
    "options": [
      {
        "label": "A",
        "text": "Transport Layer.",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Data Link Layer.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Application Layer.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Physical Layer",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "source": {
      "file": "[CE] questions.pdf",
      "exam": "K-Companies",
      "year": 2016,
      "tier": "gold",
      "originalNumber": 53
    },
    "keyProvenance": "answer_page",
    "flags": [],
    "keyVerified": true,
    "needsReview": false,
    "dedupeHash": "870751df96d7c090eeaf7d4243e20c41b5db20a4",
    "explanation": "The transport layer (TCP) provides reliability end to end: sequence numbers, acknowledgements, retransmission and flow control between the two end processes. Data Link is the trap: it only gives reliability across a single hop (node to node), not across the whole path."
  },
  {
    "id": "ce2016-q054",
    "type": "mcq",
    "topic": "computer-architecture",
    "subtopic": "instruction-types",
    "stem": "___________ instructions change the flow of the program.",
    "options": [
      {
        "label": "A",
        "text": "Data Transfer (or Handling).",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Arithmetic (and Logic).",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Branch (or Control Flow).",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Registers",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "[CE] questions.pdf",
      "exam": "K-Companies",
      "year": 2016,
      "tier": "gold",
      "originalNumber": 54
    },
    "keyProvenance": "answer_page",
    "flags": [],
    "keyVerified": true,
    "needsReview": false,
    "dedupeHash": "e7a45a79f15dc89a1f7f27666734509b40ba9424",
    "explanation": "Branch / control-flow instructions (JMP, BEQ, CALL, RET) work by writing a new value into the program counter, which is exactly what changes the flow of execution. Data-transfer and arithmetic instructions only move or compute values and leave the PC to advance sequentially."
  }
]
