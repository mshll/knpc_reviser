[
  {
    "id": "sample1-q003",
    "type": "mcq",
    "topic": "cloud-computing",
    "subtopic": "virtualization",
    "stem": "Which technology enables multiple virtual machines on one physical server?",
    "options": [
      {
        "label": "A",
        "text": "Encryption",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Virtualization",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Load balancing",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Firewall",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "source": {
      "file": "Sample-1.pdf",
      "exam": "bank",
      "tier": "practice",
      "originalNumber": 3
    },
    "keyProvenance": "answer_page",
    "flags": [],
    "keyVerified": true,
    "needsReview": false,
    "dedupeHash": "e9e6c93594df5b6d239ea035f3a209ec8128f584",
    "explanation": "Virtualization inserts a hypervisor between hardware and guests, letting it multiplex one physical CPU, memory and NIC into many isolated virtual machines. Encryption, load balancing and firewalls are all security or traffic functions and create no VMs."
  },
  {
    "id": "sample1-q004",
    "type": "mcq",
    "topic": "cloud-computing",
    "subtopic": "cloud-benefits",
    "stem": "Which of the following is a benefit of cloud computing?",
    "options": [
      {
        "label": "A",
        "text": "High maintenance cost",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Limited scalability",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Automatic updates",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Manual backup",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "Sample-1.pdf",
      "exam": "bank",
      "tier": "practice",
      "originalNumber": 4
    },
    "keyProvenance": "answer_page",
    "flags": [],
    "keyVerified": true,
    "needsReview": false,
    "dedupeHash": "4ed90e3fc4b6e790f17b46c119d3fa9ca545ec27",
    "explanation": "Only C is stated as an advantage: the provider patches and upgrades the platform, so customers get updates automatically. A and B are worded as drawbacks (cloud lowers maintenance cost and gives near-unlimited scalability) and D is the manual work cloud backup services remove."
  },
  {
    "id": "sample1-q005",
    "type": "mcq",
    "topic": "cloud-computing",
    "subtopic": "service-models",
    "stem": "In which model does the user have the least control over infrastructure?",
    "options": [
      {
        "label": "A",
        "text": "IaaS",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "PaaS",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "SaaS",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "Private Cloud",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "Sample-1.pdf",
      "exam": "bank",
      "tier": "practice",
      "originalNumber": 5
    },
    "keyProvenance": "answer_page",
    "flags": [],
    "keyVerified": true,
    "needsReview": false,
    "dedupeHash": "24ae002d8f6d86aa3486b95210780526dd688b17",
    "explanation": "Customer control decreases along IaaS > PaaS > SaaS. In IaaS you manage OS and runtime, in PaaS only the app and data, and in SaaS you consume a finished application and control nothing below it, so SaaS gives the least infrastructure control. Private Cloud is a deployment model, not a service model, so it does not belong on this scale."
  },
  {
    "id": "sample1-q006",
    "type": "mcq",
    "topic": "computer-architecture",
    "subtopic": "system-bus",
    "stem": "What is the role of a `bus` in a computer system?",
    "options": [
      {
        "label": "A",
        "text": "To store data permanently",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "To execute programs",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "To provide communication pathways between components",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "To manage power supply",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "Sample-1.pdf",
      "exam": "bank",
      "tier": "practice",
      "originalNumber": 6
    },
    "keyProvenance": "answer_page",
    "flags": [],
    "keyVerified": true,
    "needsReview": false,
    "dedupeHash": "e96af6378d408b502b448ade79911b19724de942",
    "explanation": "A bus is the shared set of address, data and control lines that carries signals between CPU, memory and I/O modules, so its role is communication. Storage is memory's job and execution is the CPU's job."
  },
