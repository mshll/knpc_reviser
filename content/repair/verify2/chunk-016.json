  {
    "id": "sample1-q010",
    "type": "mcq",
    "topic": "general-it",
    "subtopic": "encryption",
    "stem": "Which technique protects data by converting it into unreadable form?",
    "options": [
      {
        "label": "A",
        "text": "Backup",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Encryption",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Compression",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Replication",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "source": {
      "file": "Sample-1.pdf",
      "exam": "bank",
      "tier": "practice",
      "originalNumber": 10
    },
    "keyProvenance": "answer_page",
    "flags": [],
    "keyVerified": true,
    "needsReview": false,
    "dedupeHash": "ec93fe5a724231a01ce498edd47b707a1cba7cdc",
    "explanation": "Encryption transforms plaintext into ciphertext that is unreadable without the key. Compression also makes data unreadable to the eye but is fully reversible by anyone with no secret, so it protects nothing; backup and replication just copy the data."
  },
