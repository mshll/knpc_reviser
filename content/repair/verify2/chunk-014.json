  },
  {
    "id": "koc2012-q097",
    "type": "mcq",
    "topic": "programming",
    "subtopic": "modulo",
    "stem": "In computer languages, 17 mod 5 is:",
    "options": [
      {
        "label": "A",
        "text": "3",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "22",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "2",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "12",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 97
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "7b2f1f305e66b8784dc549d932f335baedca6249",
    "explanation": "mod returns the remainder of integer division: 17 = 3 * 5 + 2, so 17 mod 5 = 2. The distractor 3 is the quotient, not the remainder."
  },
  {
    "id": "koc2012-q098",
    "type": "mcq",
    "topic": "number-systems",
    "subtopic": "binary-to-decimal",
    "stem": "The decimal conversion for the binary number 1100010 is:",
    "options": [
      {
        "label": "A",
        "text": "35",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "122",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "99",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "98",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 98
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "c236e4886cbff263a278963cb4ffc6be9efa8652",
    "explanation": "Bit weights from the left are 64, 32, 16, 8, 4, 2, 1, so 1100010 = 64 + 32 + 2 = 98. The 122 distractor comes from misreading the bit positions."
  },
  {
    "id": "koc2012-q099",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "radio-propagation",
    "stem": "Long distance (over 2000 km) HF radio communication systems make use of:",
    "options": [
      {
        "label": "A",
        "text": "Space wave propagation",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Surface wave propagation",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Multi-hop ground wave propagation",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Sky wave propagation through ionosphere",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 99
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "972038fcc989e4c05b3bbcaded8565630b710887",
    "explanation": "HF signals (3 to 30 MHz) are refracted back to earth by the ionosphere, so sky wave propagation carries them thousands of kilometres beyond the horizon. Surface waves attenuate quickly with distance, and space waves are line of sight and limited by the horizon."
  },
  {
    "id": "koc2012-q100",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "osi-model",
    "stem": "Which one of the following is not a network layer:",
    "options": [
      {
        "label": "A",
        "text": "Data Link",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Presentation",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Application",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Communication",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
