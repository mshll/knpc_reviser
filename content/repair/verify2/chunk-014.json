[
  {
    "id": "koc2012-q090",
    "type": "mcq",
    "topic": "databases",
    "subtopic": "data-dictionary",
    "stem": "This is a collection of descriptions about data objects that is created for the benefit of programmers and others who might need to refer to them.",
    "options": [
      {
        "label": "A",
        "text": "Data Dictionary",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Stored Procedure",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Catalog",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Virtual File Allocation Table",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 90
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "3af13c48a810e8da1688ee0b9cda9e48344f13c6",
    "explanation": "A data dictionary is the metadata repository holding descriptions of data objects: table names, column names, data types, and constraints, for programmers and other users to consult. A stored procedure is executable code, not a description of data."
  },
  {
    "id": "koc2012-q091",
    "type": "mcq",
    "topic": "databases",
    "subtopic": "tablespaces",
    "stem": "The main benefit of spreading multiple tablespaces across disks is to:",
    "options": [
      {
        "label": "A",
        "text": "Reduce disk fragmentation",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Increase tablespace sizes",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Minimize disk I/O connection",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 91
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "a3cbc9d3d4c3695a6d027366ec7cd722d6f46f81",
    "explanation": "Putting tablespaces on separate physical disks lets their reads and writes proceed in parallel on different spindles and controllers, minimizing I/O contention on any single disk. It does not increase tablespace size, and fragmentation is a separate concern."
  },
  {
    "id": "koc2012-q092",
    "type": "true_false",
    "topic": "databases",
    "subtopic": "null-values",
    "stem": "In Oracle a NULL value means that the value is not known.",
    "options": [
      {
        "label": "A",
        "text": "True",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "False",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 92
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "a4010400d659794ea3aef5d04e02c7cd6fa716af",
    "explanation": "In Oracle, NULL means the value is unknown, missing, or not applicable. It is not zero and not an empty string, which is why NULL = NULL does not evaluate to true and you must use IS NULL."
  },
  {
    "id": "koc2012-q093",
    "type": "mcq",
    "topic": "databases",
    "subtopic": "data-hierarchy",
    "stem": "Which order of correct hierarchy from the largest to the smallest from the list below:",
    "options": [
      {
        "label": "A",
        "text": "Fields, records, files",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Records, fields, files",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "File, fields, records",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "File, record, fields",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 93
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "23b132dd9b15e11616894746b82be60fca0f3013",
    "explanation": "The data hierarchy from largest to smallest is file > record > field: a file contains many records, and each record contains several fields (which in turn contain characters). Only D lists them in that order."
  },
  {
    "id": "koc2012-q094",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "logic-gates",
    "stem": "What is the correct answer when using AND gate true table in the digital circuits design:",
    "options": [
      {
        "label": "A",
        "text": "1 AND 1 is 0",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "1 AND 0 is 1",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "1 AND 1 is 0",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "1 AND 1 is 1",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 94
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "ec5c463847eed3417d6a0e66139af5dc83736461",
    "explanation": "An AND gate outputs 1 only when every input is 1, so 1 AND 1 = 1. Note options A and C print the same false claim, and 1 AND 0 = 0, not 1."
  },
  {
    "id": "koc2012-q095",
    "type": "mcq",
    "topic": "digital-logic",
    "subtopic": "logic-gates",
    "stem": "What is the correct answer when using OR gate true table in the digital circuits design:",
    "options": [
      {
        "label": "A",
        "text": "1 OR 0 is 0",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "1 OR 1 is 0",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "0 OR 1 is 1",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "0 OR 0 is 1",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 95
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "c1f6c120dfe90e4fba85f40375e4447f6f5c6499",
    "explanation": "An OR gate outputs 1 when at least one input is 1, so 0 OR 1 = 1. Every other option inverts a row of the truth table (1 OR 0 = 1, 1 OR 1 = 1, 0 OR 0 = 0)."
  },
  {
