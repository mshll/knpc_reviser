    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 104
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "2763795e52342d047dea02465c135f3e0a0c83db",
    "explanation": "1 PB = 1024 TB, so a terabyte is less than a petabyte. Every other option is smaller than a TB: 1000 MB is about 1 GB, 100 GB is 0.1 TB, and one million KB is also about 1 GB."
  }
]
