  {
    "id": "mock2018-q051",
    "type": "mcq",
    "topic": "data-structures-algorithms",
    "subtopic": "hashing",
    "stem": "In a hash table, what is direct addressing?",
    "options": [
      {
        "label": "A",
        "text": "Distinct array position for every possible key.",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Fewer array positions than keys.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Fewer keys than array positions.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of the mentioned.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "Direct addressing is possible only when we can afford to allocate an array that has one position for every possible key.",
    "explanationSource": "source",
    "source": {
