  {
    "id": "mock2018-q056",
    "type": "mcq",
    "topic": "data-structures-algorithms",
    "subtopic": "hashing",
    "stem": "What is simple uniform hashing?",
    "options": [
      {
        "label": "A",
        "text": "Every element has equal probability of hashing into any of the slots.",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "A weighted probabilistic method is used to hash elements into the slots.",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "All of the mentioned.",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of the mentioned.",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "explanation": "In simple uniform hashing, any given element is equally likely to hash into any of the slots available in the array.",
    "explanationSource": "source",
