        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 77
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "6f9ab1a5d3e31a256d796e9aa780db8490947179",
    "explanation": "SRAM stands for Static RAM, that is static memory. It is called static because it holds its contents for as long as power is applied, with no refresh cycle, unlike DRAM (Dynamic RAM) which must be refreshed continuously."
  },
  {
    "id": "koc2012-q078",
    "type": "mcq",
    "topic": "computer-architecture",
    "subtopic": "cpu-components",
    "stem": "Which of the following is not one of the 3 major components of the CPU?",
    "options": [
      {
        "label": "A",
        "text": "The I/O unit",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "The arithmetic unit",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "The control unit",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 78
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "4b358d097192912c49172d9a7819852c10f4393a",
    "explanation": "The three major components of the CPU are the arithmetic (logic) unit, the control unit and the registers. The I/O unit handles communication with peripherals and lives outside the CPU, so it is the one that does not belong."
  },
  {
    "id": "koc2012-q079",
    "type": "mcq",
    "topic": "networking",
    "subtopic": "units",
    "stem": "MBPs stand for:",
    "options": [
      {
        "label": "A",
        "text": "Mega bits per second",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "Mega Bytes per second",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 79
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "23c8980662feea1146c6a8cfbc3edbbe189b20f4",
    "explanation": "Mbps means megabits per second, with a lowercase b for bits. Mega Bytes per second is the classic trap: a byte is 8 bits, so MB/s is 8 times larger than Mb/s. Network link speeds are quoted in bits per second by convention."
  },
  {
    "id": "koc2012-q080",
    "type": "mcq",
    "topic": "computer-architecture",
    "subtopic": "performance",
    "stem": "One of the following does not affect the speed of computing in computers:",
    "options": [
      {
        "label": "A",
        "text": "CPU",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Memory",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Hard Disk",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 80
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "54834f5d44255f7bd76bdd894fa916f64c9dfd03",
    "explanation": "The hard disk is storage and I/O: it affects how fast programs load and how fast files are read, but not the speed of computing itself. CPU clock speed and memory speed and size both directly determine how fast instructions are executed, so they do affect computing speed."
  },
  {
    "id": "koc2012-q081",
    "type": "mcq",
    "topic": "number-systems",
    "subtopic": "units",
    "stem": "The result of dividing one Terabyte by one GB is:",
    "options": [
      {
        "label": "A",
        "text": "100000 Bytes",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "10000 Bytes",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "1000 Bytes",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "None of the above",
        "isCorrect": true
      }
    ],
    "answerOptionLabels": [
      "D"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 81
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "4ef0657e8bc03745c8dc4f3ac41e72b3f1666247",
    "explanation": "1 TB / 1 GB = 1024 (binary) or 1000 (decimal), and dividing bytes by bytes cancels the units, so the result is a plain number, not a quantity of bytes. Every listed option is labelled 'Bytes', so all three are wrong on units and the answer is 'None of the above'. The trap is picking '1000 Bytes' because 1000 looks like the right magnitude."
  },
