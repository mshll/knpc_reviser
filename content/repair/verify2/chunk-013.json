  {
    "id": "koc2012-q087",
    "type": "mcq",
    "topic": "misc",
    "subtopic": "probability",
    "stem": "Suppose you have a jar that contains 4 Red marbles and 6 Blue marbles. The probability of picking up a Red marble at random is:",
    "options": [
      {
        "label": "A",
        "text": "1/4",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "1/10",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "4/10",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "None of the above",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "C"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 87
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "ec5fc6410ae3746ec4a1d16df16fb448a6ffc755",
    "explanation": "There are 4 + 6 = 10 marbles and 4 of them are red, so P(red) = 4/10 = 0.4. The 1/4 distractor is the red-to-blue ratio confusion, and 1/10 is the chance of drawing one specific marble."
  },
