        "text": "Analysis, Code, and Test",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Serial, Random, and Continuous",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "Internal, Conceptual, and External",
        "isCorrect": true
      },
      {
        "label": "D",
