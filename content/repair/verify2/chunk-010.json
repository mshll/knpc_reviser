[
  {
    "id": "koc2012-q001",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "os-role",
    "stem": "The function of an Operating System is to:",
    "options": [
      {
        "label": "A",
        "text": "Process input data",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "Manage and allocate computer hardware and software resources",
        "isCorrect": true
      },
      {
        "label": "C",
        "text": "Display Error messages for computer operators",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "Print reports",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "B"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 1
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "10728132e161cb0285e01337095c30f3b9e138c1",
    "explanation": "The OS is the resource manager: it allocates the CPU, memory, I/O devices and files among competing programs and users, and provides the interface between hardware and application software. Processing data, printing reports and showing errors are things applications or utilities do on top of the OS, not the OS's defining function."
  },
  {
    "id": "koc2012-q002",
    "type": "mcq",
    "topic": "operating-systems",
    "subtopic": "unix-commands",
    "stem": "What is the Unix command to display a file on a terminal, one screen-full at a time:",
    "options": [
      {
        "label": "A",
        "text": "more",
        "isCorrect": true
      },
      {
        "label": "B",
        "text": "cat",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "dir",
        "isCorrect": false
      },
      {
        "label": "D",
        "text": "ls",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
      "A"
    ],
    "source": {
      "file": "KOC 2012 EXAM (2).pdf",
      "exam": "KOC",
      "tier": "gold",
      "year": 2012,
      "originalNumber": 2
    },
    "keyProvenance": "inline_bold",
    "keyVerified": true,
    "needsReview": false,
    "flags": [],
    "dedupeHash": "3c6507865f1803c6360d86115fe85e15ee59cd0f",
    "explanation": "'more' is the classic Unix pager: it prints one screen-full and waits for a keypress before showing the next. 'cat' is the trap here, it prints the file but dumps the whole thing without pausing; 'ls' (and DOS 'dir') list directory names, not file contents."
  },
