  },
  {
    "id": "koc2012-q010",
    "type": "mcq",
    "topic": "number-systems",
    "subtopic": "units",
    "stem": "How many bits are in a byte?",
    "options": [
      {
        "label": "A",
        "text": "32",
        "isCorrect": false
      },
      {
        "label": "B",
        "text": "16",
        "isCorrect": false
      },
      {
        "label": "C",
        "text": "8",
        "isCorrect": true
      },
      {
        "label": "D",
        "text": "4",
        "isCorrect": false
      }
    ],
    "answerOptionLabels": [
